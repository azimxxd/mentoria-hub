# --- AI Assistant (optional, Hugging Face) ---
# The assistant calls the free Hugging Face Inference router (OpenAI-compatible).
# Create a token at https://huggingface.co/settings/tokens and set it here.
# Without it the assistant gracefully falls back to the built-in deterministic
# recommendation engine, so the demo always works.
HF_TOKEN=
# Optional: override the model (default: meta-llama/Llama-3.1-8B-Instruct:novita)
HF_MODEL=

# --- Telegram reminder bot (optional) ---
# Create a bot with @BotFather, paste the token here, then run: npm run bot
# It sends a reminder ~30 min before each live online lesson.
TELEGRAM_BOT_TOKEN=
# Public bot username (no @) for the "Connect Telegram" deep link on the site.
NEXT_PUBLIC_TELEGRAM_BOT=MentoriaHub_bot

# --- Supabase (real backend) ---
# Without these the app falls back to the local seed/localStorage data layer.
# To enable the real Postgres backend (shared data, real auth, RLS):
#   1. Create a project at https://supabase.com
#   2. In the SQL editor run supabase/schema.sql, then supabase/seed.sql
#   3. Auth → Providers → Email: turn OFF "Confirm email" (so sign-up logs in instantly)
#   4. Settings → API: copy the values below
#   5. Create the demo users:  npm run seed:supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — used ONLY by scripts/seed-supabase.mjs. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
