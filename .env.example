# --- AI Assistant (optional) ---
# Without this key the assistant gracefully falls back to the built-in
# deterministic recommendation engine, so the demo always works.
ANTHROPIC_API_KEY=

# --- Supabase (optional production backend) ---
# The deployed MVP runs on a localStorage data layer with seeded demo data and
# needs NO env vars. To switch to the real Postgres backend, create a Supabase
# project, run supabase/schema.sql + supabase/seed.sql, and set these:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
